{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spotlightadvocate.local/schemas/document.json",
  "title": "Spotlight Advocate Document",
  "description": "Content source for SADS. Formatting never lives here — only structured content. Presentation is decided by the renderer.",
  "type": "object",
  "required": [
    "number",
    "title",
    "version",
    "category",
    "owner",
    "approved",
    "purpose",
    "scope",
    "sections",
    "revision_history"
  ],
  "additionalProperties": false,
  "properties": {
    "number": {
      "type": "string",
      "pattern": "^SA-[0-9]{3,}$",
      "description": "Document number within the category band, e.g. SA-100 (Legal), SA-200 (Operations)"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "examples": ["1.0", "1.1"]
    },
    "category": {
      "type": "string",
      "enum": [
        "Legal",
        "Operations",
        "Sales",
        "Marketing",
        "HR",
        "Technical",
        "Finance",
        "Administration",
        "Corporate",
        "Production",
        "Licensing"
      ],
      "description": "Semantic purpose category. Prefer primary categories; legacy aliases map into the same number bands."
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "approved": {
      "type": "string",
      "minLength": 1,
      "examples": ["Pending", "Approved", "Draft"]
    },
    "purpose": {
      "type": "string",
      "description": "Canonical purpose; also assembled as a leading Purpose section when generating"
    },
    "scope": {
      "type": "string",
      "description": "Canonical scope; also assembled as a leading Scope section when generating"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heading", "body"],
        "additionalProperties": false,
        "properties": {
          "heading": { "type": "string" },
          "body": {
            "type": "string",
            "description": "May include reusable clause refs such as {{clause:liability}} or {{ Standard Confidentiality Clause }}. For tables, may contain a pipe table."
          },
          "type": {
            "type": "string",
            "enum": [
              "section",
              "paragraph",
              "definition",
              "responsibilities",
              "procedure",
              "warning",
              "note",
              "tip",
              "signature",
              "approval",
              "appendix",
              "table",
              "image"
            ],
            "default": "section",
            "description": "Reusable building-block type (not a document template)"
          },
          "rows": {
            "type": "array",
            "description": "For type=table: array of rows, each an array of cell strings. First row is the header.",
            "items": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "src": {
            "type": "string",
            "description": "For type=image: path relative to project root, Output/Images/, or Components/Images/"
          },
          "alt": {
            "type": "string",
            "description": "For type=image: accessible alternative text"
          }
        }
      }
    },
    "revision_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "author", "notes"],
        "additionalProperties": false,
        "properties": {
          "version": { "type": "string" },
          "date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "author": { "type": "string" },
          "notes": {
            "type": "string",
            "description": "Structured revision description (rendered as table column)"
          },
          "description": {
            "type": "string",
            "description": "Alias for notes; normalized to notes on load"
          }
        }
      }
    }
  }
}
